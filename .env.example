# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080

# Paste Spotify playlist URIs here (right-click playlist → Share → Copy URI)
PLAYLIST_FOCUSED=spotify:playlist:REPLACE_ME
PLAYLIST_CALM=spotify:playlist:REPLACE_ME
PLAYLIST_MEDITATIVE=spotify:playlist:REPLACE_ME
